{
  "name": "paycrypto-payouts-node-client",
  "version": "1.0.0",
  "description": "Node.js client for PayCrypto payouts API v1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/cjs-rename.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx scripts/smoke.ts",
    "e2e": "tsx scripts/e2e.ts",
    "test:live": "tsx scripts/live-api.ts",
    "prepublishOnly": "npm run build && npm run test",
    "publish:otp": "bash scripts/publish-with-otp.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PayCryptoOne/paycrypto-payouts-node-client.git"
  },
  "bugs": {
    "url": "https://github.com/PayCryptoOne/paycrypto-payouts-node-client/issues"
  },
  "homepage": "https://github.com/PayCryptoOne/paycrypto-payouts-node-client#readme",
  "keywords": [
    "paycrypto",
    "payouts",
    "crypto"
  ],
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
